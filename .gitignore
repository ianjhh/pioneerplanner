# 1. Python Environments
venv/          #virtual environment files, unnecessary
env/
.venv/

# 2. Python Cache & Compiled Files
__pycache__/     #unnecessary tracking of python autogenerated files for script
*.py[cod]
*$py.class

# 3. Secrets & Environment Variables
.env
.env.*
*.secret

# 4. Database & Docker Volumes
pgdata/    	#map postgres data to local folder so it wont get wiped on docker restart

# 5. OS & IDE Specific Files
.DS_Store       #macOS preference file for icons in folder arrangement
.vscode/        #personal editor settings
.idea/          #personal editor settings
